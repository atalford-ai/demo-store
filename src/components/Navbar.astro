---
import config from '../../site.json';
---
<header class="navbar bg-base-100/80 backdrop-blur-md sticky top-0 z-50 border-b border-base-300/50">
  <div class="navbar-start">
    <a href="/" class="btn btn-ghost text-xl font-heading font-bold tracking-tight">
      <span class="text-accent">{config.business_name.charAt(0)}</span>{config.business_name.slice(1)}
    </a>
  </div>

  <nav class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal px-1 gap-4">
      <li><a href="#products" class="font-medium text-base tracking-wide">Shop</a></li>
      <li><a href="#categories" class="font-medium text-base tracking-wide">Categories</a></li>
      <li><a href="#about" class="font-medium text-base tracking-wide">About</a></li>
      <li><a href="#contact" class="font-medium text-base tracking-wide">Contact</a></li>
    </ul>
  </nav>

  <div class="navbar-end gap-2">
    <!-- Cart button -->
    <button id="cart-toggle" class="btn btn-ghost btn-circle relative" aria-label="Open cart">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
      </svg>
      <span id="cart-count" class="badge badge-sm badge-accent absolute -top-1 -right-1 hidden">0</span>
    </button>

    <!-- Mobile menu -->
    <div class="dropdown dropdown-end lg:hidden">
      <label tabindex="0" class="btn btn-ghost btn-circle">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
        </svg>
      </label>
      <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow-lg bg-base-200 rounded-box w-52">
        <li><a href="#products">Shop</a></li>
        <li><a href="#categories">Categories</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </div>
  </div>
</header>
