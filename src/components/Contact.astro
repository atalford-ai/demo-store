---
import config from '../../site.json';
---
<section id="contact" class="py-24 px-6 lg:px-12 bg-base-200/50">
  <div class="container mx-auto max-w-4xl">
    <div class="text-center mb-16 fade-in-up">
      <span class="badge badge-outline border-accent text-accent text-xs tracking-widest uppercase mb-4">Get in Touch</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Let's Connect</h2>
      <p class="text-base-content/60 mt-4">Questions, collabs, or just want to say what's up.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Form -->
      <div class="fade-in-up">
        <form class="space-y-6">
          <div>
            <label class="label text-sm font-medium">Name</label>
            <input type="text" placeholder="Your name" class="input input-bordered w-full bg-base-100 focus:border-accent" />
          </div>
          <div>
            <label class="label text-sm font-medium">Email</label>
            <input type="email" placeholder="you@email.com" class="input input-bordered w-full bg-base-100 focus:border-accent" />
          </div>
          <div>
            <label class="label text-sm font-medium">Message</label>
            <textarea placeholder="What's on your mind?" class="textarea textarea-bordered w-full bg-base-100 focus:border-accent h-32"></textarea>
          </div>
          <button type="submit" class="btn btn-accent w-full">
            Send Message
          </button>
        </form>
      </div>

      <!-- Info -->
      <div class="fade-in-up space-y-8" style="animation-delay: 0.2s;">
        <div>
          <h3 class="font-heading font-semibold text-lg mb-2">Visit Us</h3>
          <p class="text-base-content/60">{config.contact.address}</p>
        </div>
        <div>
          <h3 class="font-heading font-semibold text-lg mb-2">Email</h3>
          <a href={`mailto:${config.contact.email}`} class="text-accent hover:underline">{config.contact.email}</a>
        </div>
        <div>
          <h3 class="font-heading font-semibold text-lg mb-2">Phone</h3>
          <a href={`tel:${config.contact.phone}`} class="text-accent hover:underline">{config.contact.phone}</a>
        </div>
        <div>
          <h3 class="font-heading font-semibold text-lg mb-2">Follow the Movement</h3>
          <div class="flex gap-4">
            {config.social.instagram && (
              <a href={config.social.instagram} target="_blank" rel="noopener" class="btn btn-ghost btn-circle btn-sm hover:text-accent">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              </a>
            )}
            {config.social.twitter && (
              <a href={config.social.twitter} target="_blank" rel="noopener" class="btn btn-ghost btn-circle btn-sm hover:text-accent">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
            )}
            {config.social.tiktok && (
              <a href={config.social.tiktok} target="_blank" rel="noopener" class="btn btn-ghost btn-circle btn-sm hover:text-accent">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.48v-7.15a8.16 8.16 0 005.58 2.18v-3.45a4.85 4.85 0 01-1-.19z"/></svg>
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
