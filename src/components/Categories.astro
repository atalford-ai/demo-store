---
import config from '../../site.json';
const categories = config.categories;

const iconMap: Record<string, string> = {
  shirt: 'M12 2L6 7v2h12V7l-6-5zM6 11v9a2 2 0 002 2h8a2 2 0 002-2v-9',
  watch: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  palette: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01',
  scissors: 'M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243 4.243 3 3 0 004.243-4.243zm0-5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z',
};
---
<section id="categories" class="py-24 px-6 lg:px-12 bg-base-200/50">
  <div class="container mx-auto">
    <div class="text-center mb-16 fade-in-up">
      <span class="badge badge-outline border-accent text-accent text-xs tracking-widest uppercase mb-4">Browse</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Shop by Category</h2>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 stagger-children">
      {categories.map((cat) => (
        <a href="#" class="group relative rounded-2xl overflow-hidden border border-base-300/50 aspect-[4/3] flex items-end hover:border-accent/50 transition-all duration-300 hover:-translate-y-1">
          <img src={cat.image} alt={cat.name} class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
          <div class="relative p-6 text-white">
            <h3 class="font-heading font-semibold text-lg">{cat.name}</h3>
            <p class="text-sm text-white/70">{cat.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
