---
const themes = [
  'light', 'dark', 'cupcake', 'bumblebee', 'emerald', 'corporate',
  'synthwave', 'retro', 'cyberpunk', 'valentine', 'halloween',
  'garden', 'forest', 'aqua', 'lofi', 'pastel', 'fantasy',
  'wireframe', 'black', 'luxury', 'dracula', 'cmyk', 'autumn',
  'business', 'acid', 'lemonade', 'night', 'coffee', 'winter',
  'dim', 'nord', 'sunset', 'caramellatte', 'abyss', 'silk',
];
---
<div class="fixed bottom-6 left-6 z-50">
  <div class="dropdown dropdown-top">
    <label tabindex="0" class="btn btn-circle bg-base-200 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
      </svg>
    </label>
    <ul tabindex="0" class="dropdown-content mb-3 p-2 shadow-xl bg-base-200 rounded-box w-56 max-h-96 overflow-y-auto border border-base-300">
      <li class="px-3 py-1 text-xs font-bold uppercase tracking-wider text-base-content/40">Themes</li>
      {themes.map((theme) => (
        <li>
          <button
            class="theme-btn w-full text-left px-3 py-2 rounded-lg text-sm font-medium hover:bg-base-300 transition-colors capitalize flex items-center gap-3"
            data-theme-value={theme}
          >
            <div class="flex gap-0.5" data-theme={theme}>
              <span class="w-2 h-4 rounded-sm bg-primary"></span>
              <span class="w-2 h-4 rounded-sm bg-secondary"></span>
              <span class="w-2 h-4 rounded-sm bg-accent"></span>
              <span class="w-2 h-4 rounded-sm bg-neutral"></span>
            </div>
            {theme}
          </button>
        </li>
      ))}
      <li class="border-t border-base-300 mt-1 pt-1">
        <button
          class="theme-btn w-full text-left px-3 py-2 rounded-lg text-sm font-medium hover:bg-base-300 transition-colors flex items-center gap-3"
          data-theme-value="auto"
        >
          <div class="flex gap-0.5">
            <span class="w-2 h-4 rounded-sm bg-base-content/30"></span>
            <span class="w-2 h-4 rounded-sm bg-base-content/20"></span>
            <span class="w-2 h-4 rounded-sm bg-base-content/30"></span>
            <span class="w-2 h-4 rounded-sm bg-base-content/20"></span>
          </div>
          Auto (time of day)
        </button>
      </li>
    </ul>
  </div>
</div>

<script is:inline>
document.querySelectorAll('.theme-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var theme = this.dataset.themeValue;
    if (theme === 'auto') {
      localStorage.removeItem('shopfront-theme');
      var hour = new Date().getHours();
      var autoTheme = (hour < 7 || hour >= 19) ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', autoTheme);
    } else {
      localStorage.setItem('shopfront-theme', theme);
      document.documentElement.setAttribute('data-theme', theme);
    }
  });
});
</script>
