---
import config from '../../site.json';
---
<section class="min-h-[90vh] flex items-center pt-16">
  <div class="container mx-auto px-6 lg:px-12">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Text -->
      <div class="fade-in-up">
        <span class="badge badge-outline border-accent text-accent text-xs tracking-widest uppercase mb-4">New Collection</span>
        <h1 class="text-5xl md:text-7xl font-heading font-bold leading-tight mb-6">
          {config.tagline.split('.')[0]}<span class="text-accent">.</span>
          <br />
          <span class="text-base-content/60">{config.tagline.split('.').slice(1).join('.').trim()}</span>
        </h1>
        <p class="text-lg text-base-content/70 max-w-md mb-8">
          {config.description}
        </p>
        <div class="flex gap-4">
          <a href="#products" class="btn btn-accent btn-lg px-8">
            Shop Now
          </a>
          <a href="#categories" class="btn btn-outline btn-lg px-8">
            Browse
          </a>
        </div>
      </div>

      <!-- Right: Featured product image -->
      <div class="fade-in-up relative" style="animation-delay: 0.3s;">
        <div class="relative aspect-square max-w-lg mx-auto">
          <!-- Accent glow behind image -->
          <div class="absolute inset-0 bg-primary/10 rounded-3xl blur-3xl"></div>
          <div class="relative bg-base-200 rounded-3xl overflow-hidden aspect-square border border-base-300/50">
            <img src="https://images.unsplash.com/photo-1556821840-3a63f95609a7?w=800&h=800&fit=crop" alt="Featured product" class="w-full h-full object-cover" />
          </div>
          <!-- Floating badge -->
          <div class="absolute -bottom-4 -left-4 bg-base-200 border border-base-300/50 rounded-2xl p-4 shadow-xl">
            <p class="text-xs text-base-content/60 uppercase tracking-wider">Starting at</p>
            <p class="text-2xl font-heading font-bold text-accent">{config.currency_symbol}34.99</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
